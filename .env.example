# Copie este arquivo para .env e preencha os valores.

# Porta do servidor Express (backend). Padrão: 5000
PORT=5000

# Conexão com o PostgreSQL (obrigatória). O docker-compose já sobe um banco
# compatível com esta URL na porta 5433. O servidor não inicia sem isso.
DATABASE_URL=postgres://prpg:prpg@localhost:5433/prpg

# Segredo usado para assinar os tokens JWT. OBRIGATÓRIO.
# Use uma string longa e aleatória (mínimo 16 caracteres). O servidor
# não inicia sem isso. Gere uma com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# URL base da API consumida pelo frontend (Vite).
# Em produção, aponte para o domínio público (ex.: https://prpg.ufrpe.br).
# Em desenvolvimento pode deixar vazio (usa http://localhost:5000).
VITE_API_URL=

# Ambiente de execução do servidor: development (padrão) ou production.
# Em production o CORS passa a restringir as origens (ver CORS_ORIGINS).
NODE_ENV=development

# Origens autorizadas a consumir a API via navegador, separadas por vírgula.
# Usado apenas quando NODE_ENV=production. Em desenvolvimento o CORS é liberado.
# Ex.: CORS_ORIGINS=https://prpg.ufrpe.br,https://www.prpg.ufrpe.br
CORS_ORIGINS=
